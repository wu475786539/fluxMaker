POSTGRES_PASSWORD=replace-with-a-long-random-password
# go（默认）或 java。三项后台服务必须使用同一个实现。
BACKEND_IMPL=go
REDIS_PASSWORD=replace-with-a-different-long-random-password
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-at-least-12-characters
ADMIN_PORT=8080

# Admin API dependency timeouts. Keep these below the external readiness timeout.
ADMIN_REDIS_TIMEOUT_MS=2000
ADMIN_DB_CONNECT_TIMEOUT_SECONDS=2
ADMIN_DB_LOGIN_TIMEOUT_SECONDS=2
ADMIN_DB_SOCKET_TIMEOUT_SECONDS=3
ADMIN_DB_QUERY_TIMEOUT_SECONDS=2
ADMIN_DB_CANCEL_TIMEOUT_SECONDS=2
ADMIN_SELF_CHECK_STARTUP_GRACE_SECONDS=30
ADMIN_SELF_CHECK_INTERVAL_SECONDS=15
ADMIN_SELF_CHECK_TIMEOUT_SECONDS=2
ADMIN_SELF_CHECK_FAILURES=3

# Required to scrape GET /metrics. Generate with: openssl rand -hex 32
METRICS_TOKEN=
LOG_MAX_SIZE=20m
LOG_MAX_FILES=5
LOG_LEVEL=info

# Generate once with: openssl rand -base64 32
# Back it up securely. Losing or changing it makes stored credentials unreadable.
CREDENTIAL_MASTER_KEY=

# Keep disabled until Shadow has been verified.
FLUXMAKER_ENABLE_LIVE_TRADING=DISABLED
